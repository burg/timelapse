{
    "domain": "Recordings",
    "description": "Responsible for maintaining a list of available recordings, and transferring recording data between frontend and backend.",
    "types": [
        {
            "id": "RecordingId",
            "type": "integer",
            "description": "Unique replay recording identifier."
        },
        {
            "id": "MarkIndex",
            "type": "integer",
            "description": "The mark index type."
        },
        {
            "id": "Mark",
            "type": "object",
            "properties": [
               { "name": "index", "$ref": "MarkIndex", "description": "The index of this mark." },
               { "name": "timestamp", "type": "number", "description": "The timestamp of this mark." }
            ],
            "description": "The index and timestamp of an input action."
        },
        {
            "id": "ReplayInput",
            "type": "object",
            "properties": [
                { "name": "type", "type": "string", "description": "Input type." },
                { "name": "data", "type": "object", "description": "Per-input payload." }
            ]
        },
        {
            "id": "ReplayInputQueue",
            "type": "object",
            "properties": [
                { "name": "type", "type": "string", "description": "Queue type" },
                { "name": "inputs", "type": "array", "items": { "$ref": "ReplayInput"}, "description": "Inputs belonging to this queue." }
            ]
        },
        {
            "id": "ReplayRecording",
            "type": "object",
            "properties": [
                { "name": "uid", "$ref": "RecordingId", "description": "Unique recording id." },
                { "name": "dateCreated", "type": "number", "description": "Creation time of recording, in milliseconds since the epoch." },
                { "name": "memorySize", "type": "number", "description": "Approximate size of in-memory recording representation." },
                { "name": "queues", "type": "array", "items": { "$ref": "ReplayInputQueue"} }
            ],
            "description": "A replay recording serialized to JSON."
        }
    ],
    "commands": [
        {
            "name": "getSerializedRecording",
            "description": "Returns the recording serialized to a JSON object.",
            "parameters": [
                { "name": "uid", "$ref": "RecordingId" }
            ],
            "returns": [
                { "name": "recording", "$ref": "ReplayRecording", "description": "the requested recording", "optional": true }
            ]
        },
        {
            "name": "getAvailableRecordings",
            "description": "Returns uids for all available recordings.",
            "returns": [
                { "name": "recordingUids", "type": "array", "items": { "$ref": "RecordingId" } }
            ]
        }
    ],
    "events": [
        {
            "name": "recordingAdded",
            "description": "Fired when a new recording is created or found on the filesystem.",
            "parameters": [
                { "name": "uid", "$ref": "RecordingId", "description": "Id for the added recording." }
            ]
        },
        {
            "name": "recordingRemoved",
            "description": "Fired when a recording is removed and can no longer be loaded.",
            "parameters": [
                { "name": "uid", "$ref": "RecordingId", "description": "Id for the removed recording." }
            ]
        }
    ]
}
