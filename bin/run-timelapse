#!/bin/bash

# resolve links - $0 may be a link to this script
PRG="$0"

# need this for relative symlinks
while [ -h "$PRG" ] ; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
    else
    PRG="`dirname "$PRG"`/$link"
    fi
done

saveddir=`pwd`
REAL_HOME=`dirname "$PRG"`

# make it fully qualified
REAL_HOME=`cd "$REAL_HOME" && pwd`

export TIMELAPSE_SERIALIZED_RECORDING_DIR=/tmp/timelapse-recording-$(date "+%m%d-%H%M%S")
export TIMELAPSE_SERIALIZED_RECORDING_FILENAME=$TIMELAPSE_SERIALIZED_RECORDING_DIR/recording.json
export TIMELAPSE_HOME=$REAL_HOME/../

mkdir -p $TIMELAPSE_SERIALIZED_RECORDING_DIR

# for now, always run in debug mode
$TIMELAPSE_HOME/Tools/Scripts/run-safari
