#!/bin/bash

E_NOARGS=85

if [ -z "$1" ]
then
	echo "Usage: `basename $0` port" >&2
	exit $E_NOARGS
fi

if [[ $1 -lt 0 || $1 -gt 65536 ]]
then
	echo "Invalid port out of range: $1"
	exit -1
fi

port=$1
# Does not back up existing proxy settings, or consult PAC files etc.

networksetup -listallnetworkservices | sed 1d | { while read service
do
    set $service
    if networksetup -getnetworkserviceenabled "$service" | grep -q Enabled
    then
	if networksetup -setwebproxy "$service" localhost $port | grep -q Error
	then
	    echo "ERROR: Couldn't configure HTTP proxy for service: $service"
	    echo "Aborting setup..."
	    exit 1
	fi
	if networksetup -setwebproxystate "$service" on | grep -q Error
	then
	    echo "ERROR: Couldn't enable HTTP proxy for service: $service"
	    echo "Aborting setup..."
	    exit 1
	fi
	if networksetup -setsecurewebproxy "$service" localhost $port | grep -q Error
	then
	    echo "ERROR: Couldn't configure HTTPS proxy for service: $service"
	    echo "Aborting setup..."
	    exit 1
	fi
	if networksetup -setsecurewebproxystate "$service" on | grep -q Error
	then
	    echo "ERROR: Couldn't enable HTTPS proxy for service: $service"
	    echo "Aborting setup..."
	    exit 1
	fi

	done="$done $service"
    fi
done

if [ -n "$done" ]; then
    echo "Enabled web proxy for the following network services:$done"
fi
#why is this grouping needed? see http://mywiki.wooledge.org/BashFAQ/024
}