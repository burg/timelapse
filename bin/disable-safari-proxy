#!/bin/bash

# Does not revert to any previous proxy state.

networksetup -listallnetworkservices | sed 1d | { while read service
do
    set $service
    if networksetup -getnetworkserviceenabled "$service" | grep -q Enabled
    then
	if networksetup -setwebproxystate "$service" off | grep -q Error
	then
	    echo "ERROR: Couldn't disable HTTP proxy for service: $service"
	    echo "Aborting setup..."
	    exit 1
	fi
	if networksetup -setsecurewebproxystate "$service" off | grep -q Error
	then
	    echo "ERROR: Couldn't disable HTTPS proxy for service: $service"
	    echo "Aborting setup..."
	    exit 1
	fi

	done="$done $service"
    fi
done

if [ -n "$done" ]; then
    echo "Disabled web proxy for the following network services:$done"
fi
#why is this grouping needed? see http://mywiki.wooledge.org/BashFAQ/024
}